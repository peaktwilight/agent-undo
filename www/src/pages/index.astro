  <!-- Vanilla copy-button script. Tiny, no React. -->
  <script is:inline>
    document.addEventListener("click", (e) => {
      const target = e.target instanceof Element ? e.target : null;
      if (!target) return;
      const trigger = target.closest("[data-copy]");
      if (!trigger) return;
      const text = trigger.getAttribute("data-copy");
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const wrap = trigger.closest(".copy-wrap");
        if (!wrap) return;
        const copy = wrap.querySelector(".copy-icon");
        const check = wrap.querySelector(".check-icon");
        if (copy && check) {
          copy.classList.add("hidden");
          check.classList.remove("hidden");
          setTimeout(() => {
            copy.classList.remove("hidden");
            check.classList.add("hidden");
          }, 1500);
        }
      });
    });
  </script>
