---
import Layout from "../layouts/Layout.astro";
import DockNav from "../components/DockNav.tsx";

const installCmd = "curl -fsSL https://agent-undo.com/install.sh | sh";
const githubUrl = "https://github.com/peaktwilight/agent-undo";
---

<Layout>
  <DockNav client:load />

  <main>
    <!-- ============================================================ HERO -->
    <section
      class="relative min-h-screen overflow-hidden pt-28 pb-12 sm:pt-36 sm:pb-16"
    >
      <div class="mx-auto max-w-5xl px-6 text-center">
        <!-- Eyebrow -->
        <div class="animate-fade-up" style="animation-delay: 0.05s">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/[0.04] px-3 py-1 text-[11px] font-medium tracking-wide text-cyan-300"
          >
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-cyan-400"
            ></span>
            Source control for the code your agent wrote
          </span>
        </div>

        <!-- Headline -->
        <div class="animate-fade-up" style="animation-delay: 0.15s">
          <h1
            class="mt-6 text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl"
            style="font-family: 'Outfit', sans-serif"
          >
            git for humans.<br />
            <span
              class="bg-gradient-to-r from-cyan-300 via-cyan-400 to-cyan-500 bg-clip-text text-transparent"
              ><code class="font-mono">au</code> for agents.</span
            >
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-base text-[#a3a3a3] sm:text-lg">
            <strong class="text-white">agent-undo</strong> records every byte your AI coding agent writes,
            attributes it to the agent that made the change, and gives you one
            command to roll any session back. git versions your intent.
            <code class="font-mono text-cyan-300">au</code> records the agent's.
            They live alongside each other.
          </p>
        </div>

        <!-- Giant command -->
        <div class="animate-fade-up mt-12 mb-10" style="animation-delay: 0.25s">
          <div
            class="text-6xl font-bold leading-[0.9] tracking-tighter text-white sm:text-7xl md:text-8xl"
            style="font-family: 'JetBrains Mono', monospace"
          >
            au <span class="text-cyan-400">oops</span>
          </div>
          <p
            class="mt-3 text-[11px] uppercase tracking-[0.2em] text-[#737373]"
          >
            two letters &middot; one word &middot; your code is back
          </p>
        </div>

        <!-- CTAs -->
        <div
          class="animate-fade-up flex flex-col items-center justify-center gap-3 sm:flex-row"
          style="animation-delay: 0.35s"
        >
          <div class="copy-wrap group relative inline-flex items-center">
            <code
              class="block cursor-pointer select-all rounded-lg border border-[#404040] bg-[#171717] px-5 py-3 pr-12 text-left text-sm font-mono text-white transition-colors hover:border-cyan-400/40"
              data-copy={installCmd}
            >
              {installCmd}
            </code>
            <button
              class="copy-btn absolute right-2 rounded-md p-1.5 text-[#737373] transition-all hover:bg-white/10 hover:text-white"
              aria-label="Copy install command"
              data-copy={installCmd}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="copy-icon"
              >
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"
                ></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                ></path>
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="check-icon hidden text-cyan-400"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </button>
          </div>

          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-white bg-white px-5 py-3 text-sm font-medium text-black transition-colors hover:bg-white/90"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
            Star on GitHub
          </a>
        </div>
        <p
          class="animate-fade-up mt-4 text-xs text-[#737373]"
          style="animation-delay: 0.45s"
        >
          MIT OR Apache-2.0 &middot; macOS &middot; Linux &middot; Windows
        </p>

        <!-- Terminal mockup -->
        <div
          class="animate-fade-up mx-auto mt-14 max-w-3xl"
          style="animation-delay: 0.5s"
        >
          <div
            class="overflow-hidden rounded-xl border border-[#404040] shadow-[0_0_80px_-15px_rgba(6,182,212,0.25)] transition-all duration-500 hover:border-cyan-400/30"
          >
            <div
              class="flex items-center gap-2 border-b border-[#404040] bg-[#262626] px-4 py-2.5"
            >
              <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-white/10"></div>
                <div class="h-3 w-3 rounded-full bg-white/10"></div>
                <div class="h-3 w-3 rounded-full bg-white/10"></div>
              </div>
              <span class="ml-2 font-mono text-xs text-[#737373]"
                >~/my-project &mdash; au oops</span
              >
            </div>
            <div
              class="space-y-1 bg-[#0a0a0a] p-5 text-left font-mono text-[13px] leading-relaxed sm:text-sm"
            >
              <div class="text-[#737373]">$ au oops</div>
              <div>&nbsp;</div>
              <div class="text-amber-400">
                &#9888;&nbsp;&nbsp;Last agent action: <span class="text-white"
                  >claude-code</span
                >, session 14:32&ndash;14:34, edited 5 files
              </div>
              <div class="pl-6 text-[#a3a3a3]">
                src/auth.rs <span class="text-red-400">(-87)</span> <span
                  class="text-emerald-400">+12</span
                >
              </div>
              <div class="pl-6 text-[#a3a3a3]">
                src/middleware.rs <span class="text-red-400">(-23)</span> <span
                  class="text-emerald-400">+5</span
                >
              </div>
              <div class="pl-6 text-[#a3a3a3]">
                src/lib.rs <span class="text-red-400">(-4)</span> <span
                  class="text-emerald-400">+1</span
                >
              </div>
              <div class="pl-6 text-[#a3a3a3]">
                tests/auth.rs <span class="text-red-400">(deleted)</span>
              </div>
              <div class="pl-6 text-[#a3a3a3]">
                Cargo.toml <span class="text-red-400">(-2)</span> <span
                  class="text-emerald-400">+0</span
                >
              </div>
              <div>&nbsp;</div>
              <div class="text-white">
                Roll back this entire session? <span class="text-cyan-400"
                  >[Y/n]</span
                > <span class="inline-block h-4 w-2 animate-pulse bg-cyan-400 align-middle"
                ></span>
              </div>
            </div>
          </div>
          <p class="mt-3 text-center text-[11px] text-[#737373]">
            Two letters &middot; one word &middot; your code is back.
          </p>
        </div>
      </div>
    </section>

    <!-- ===================================================== CATEGORY -->
    <section
      id="category"
      class="border-t border-white/5 py-16 sm:py-24 md:py-32"
    >
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-12 text-center">
          <p class="mb-3 text-[11px] uppercase tracking-[0.2em] text-cyan-400/80">
            The shift
          </p>
          <h2
            class="text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl"
            style="font-family: 'Outfit', sans-serif"
          >
            Source control assumes a human writer.<br />
            <span class="text-cyan-300">AI broke that assumption.</span>
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <!-- git side -->
          <div class="rounded-xl border border-[#404040] bg-[#171717] p-6">
            <p class="mb-3 text-[11px] uppercase tracking-[0.2em] text-[#737373]">
              git
            </p>
            <p class="mb-4 text-base font-medium text-white">
              Versions human <em class="not-italic text-cyan-300">intent</em>.
            </p>
            <ul class="space-y-2 text-sm text-[#a3a3a3]">
              <li>&middot; You commit when you mean to.</li>
              <li>&middot; Every change is a deliberate act.</li>
              <li>&middot; History reflects what you wanted to keep.</li>
              <li>&middot; <code class="text-cyan-300">git blame</code> tells you which human wrote each line.</li>
            </ul>
          </div>

          <!-- au side -->
          <div class="rounded-xl border border-cyan-400/30 bg-cyan-400/[0.04] p-6">
            <p class="mb-3 text-[11px] uppercase tracking-[0.2em] text-cyan-300">
              <code>au</code>
            </p>
            <p class="mb-4 text-base font-medium text-white">
              Records agent <em class="not-italic text-cyan-300">action</em>.
            </p>
            <ul class="space-y-2 text-sm text-[#a3a3a3]">
              <li>&middot; Every byte is captured on write.</li>
              <li>&middot; No deliberate act required.</li>
              <li>&middot; History reflects what actually happened.</li>
              <li>&middot; <code class="text-cyan-300">au blame</code> tells you which agent wrote each line.</li>
            </ul>
          </div>
        </div>

        <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-[#a3a3a3]">
          A 5-minute Claude session can produce 200 file writes. git sees zero of
          them until you type <code class="text-cyan-300">git add</code>.
          <code class="text-cyan-300">au</code> sees all of them, the moment they hit disk,
          tagged with the agent that made them.
        </p>
        <p class="mt-2 text-center text-sm font-medium text-white">
          They're not competitors. They're complements.
        </p>
      </div>
    </section>

    <!-- ===================================================== FEATURES -->
    <section
      id="features"
      class="border-t border-white/5 py-16 sm:py-24 md:py-32"
    >
      <div class="mx-auto max-w-5xl px-6">
        <div class="mb-12 text-center">
          <p
            class="mb-3 text-[11px] uppercase tracking-[0.2em] text-cyan-400/80"
          >
            Three things it does
          </p>
          <h2
            class="text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl"
            style="font-family: 'Outfit', sans-serif"
          >
            Observability. Attribution. Reversibility.
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-sm text-[#a3a3a3]">
            The three primitives every AI-edited codebase needs &mdash; and that
            no editor ships today.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          <!-- Card 1 -->
          <div
            class="group rounded-xl border border-[#404040] bg-[#171717] p-6 transition-colors hover:border-cyan-400/30"
          >
            <div
              class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg border border-cyan-400/30 bg-cyan-400/10 text-cyan-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 17a10 10 0 1 0-9.9 10"></path>
                <path d="M22 22 18 18"></path>
                <path d="m18 22 4-4"></path>
                <circle cx="12" cy="12" r="4"></circle>
              </svg>
            </div>
            <h3 class="mb-2 text-base font-semibold">Snapshot everything</h3>
            <p class="text-sm leading-relaxed text-[#a3a3a3]">
              Every file write, captured before it hits disk.
              Content-addressable. Deduplicated. Lives in
              <code class="text-cyan-300">.agent-undo/</code> next to your repo.
            </p>
          </div>

          <!-- Card 2 -->
          <div
            class="group rounded-xl border border-[#404040] bg-[#171717] p-6 transition-colors hover:border-cyan-400/30"
          >
            <div
              class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg border border-cyan-400/30 bg-cyan-400/10 text-cyan-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 11h-6"></path>
                <path d="M22 7h-6"></path>
                <path d="M22 15h-6"></path>
              </svg>
            </div>
            <h3 class="mb-2 text-base font-semibold">Attribute every edit</h3>
            <p class="text-sm leading-relaxed text-[#a3a3a3]">
              Know exactly which agent &mdash; Claude Code, Cursor, Cline, Aider
              &mdash; touched which file, in which session, with which prompt.
              Like
              <code class="text-cyan-300">git blame</code>, but for AI.
            </p>
          </div>

          <!-- Card 3 -->
          <div
            class="group rounded-xl border border-[#404040] bg-[#171717] p-6 transition-colors hover:border-cyan-400/30"
          >
            <div
              class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg border border-cyan-400/30 bg-cyan-400/10 text-cyan-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 7v6h6"></path>
                <path d="M21 17a9 9 0 0 0-15-6.7L3 13"></path>
              </svg>
            </div>
            <h3 class="mb-2 text-base font-semibold">One-command rollback</h3>
            <p class="text-sm leading-relaxed text-[#a3a3a3]">
              <code class="text-cyan-300">au oops</code> undoes the last
              agent session as one atomic operation. Safe. Instant. Reversible.
              The undo of the undo is one command away.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================== INSTALL -->
    <section
      id="install"
      class="border-t border-white/5 py-16 sm:py-24 md:py-32"
    >
      <div class="mx-auto max-w-3xl px-6 text-center">
        <p class="mb-3 text-[11px] uppercase tracking-[0.2em] text-cyan-400/80">
          Install
        </p>
        <h2
          class="mb-4 text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl"
          style="font-family: 'Outfit', sans-serif"
        >
          One line. Zero config.
        </h2>
        <p class="mx-auto mb-10 max-w-xl text-sm text-[#a3a3a3]">
          A single 5MB Rust binary. No daemons to babysit, no signup, no
          telemetry. Your code never leaves your machine.
        </p>

        <div class="mb-8 flex justify-center">
          <div class="copy-wrap group relative inline-flex items-center">
            <code
              class="block cursor-pointer select-all rounded-lg border border-[#404040] bg-[#171717] px-6 py-4 pr-14 text-left font-mono text-sm text-white transition-colors hover:border-cyan-400/40 sm:text-base"
              data-copy={installCmd}
            >
              {installCmd}
            </code>
            <button
              class="copy-btn absolute right-3 rounded-md p-1.5 text-[#737373] transition-all hover:bg-white/10 hover:text-white"
              aria-label="Copy install command"
              data-copy={installCmd}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="copy-icon"
              >
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"
                ></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                ></path>
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="check-icon hidden text-cyan-400"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </button>
          </div>
        </div>

        <div
          class="mx-auto grid max-w-2xl grid-cols-1 gap-3 text-left sm:grid-cols-3"
        >
          <div
            class="rounded-lg border border-[#404040] bg-[#171717] p-4 text-xs text-[#a3a3a3]"
          >
            <div class="mb-1 font-mono text-cyan-400">$ au init</div>
            sets up <code>.agent-undo/</code>, starts the watcher daemon
          </div>
          <div
            class="rounded-lg border border-[#404040] bg-[#171717] p-4 text-xs text-[#a3a3a3]"
          >
            <div class="mb-1 font-mono text-cyan-400">$ au log</div>
            see the timeline of every AI edit, filterable by agent
          </div>
          <div
            class="rounded-lg border border-[#404040] bg-[#171717] p-4 text-xs text-[#a3a3a3]"
          >
            <div class="mb-1 font-mono text-cyan-400">$ au oops</div>
            the panic button &mdash; undo the last agent session
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================== VILLAIN -->
    <section class="border-t border-white/5 py-16 sm:py-24 md:py-32">
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-12 text-center">
          <p
            class="mb-3 text-[11px] uppercase tracking-[0.2em] text-cyan-400/80"
          >
            Why this exists
          </p>
          <h2
            class="text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl"
            style="font-family: 'Outfit', sans-serif"
          >
            Your editor's undo button is broken.
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-sm text-[#a3a3a3]">
            Don't take our word for it. Take it from Cursor's own staff and
            users, on the record, on their own forum.
          </p>
        </div>

        <div class="space-y-8">
          <!-- Quote 1: deanrie -->
          <figure
            class="rounded-r-lg border-l-2 border-cyan-400 bg-[#171717]/60 px-6 py-5 sm:px-8 sm:py-6"
          >
            <blockquote
              class="text-lg leading-relaxed text-white sm:text-xl md:text-2xl"
              style="font-family: 'Outfit', sans-serif"
            >
              &ldquo;This is a known issue, a bug caused by a conflict between
              the Agent Review Tab and file editing.&rdquo;
              <br />
              <span class="text-cyan-300"
                >&ldquo;Close the Agent Review Tab before the agent makes
                edits.&rdquo;</span
              >
            </blockquote>
            <figcaption class="mt-4 text-xs text-[#737373]">
              &mdash; <span class="text-[#a3a3a3]">deanrie</span>, Cursor staff
              &middot; Jan 16, 2026 &middot;
              <a
                href="https://forum.cursor.com/t/agent-code-changes-are-automatically-deleted/149024"
                target="_blank"
                rel="noopener"
                class="underline decoration-white/20 underline-offset-2 hover:text-white hover:decoration-white/50"
                >forum.cursor.com</a
              >
            </figcaption>
          </figure>

          <!-- Quote 2: jonneal3 -->
          <figure
            class="rounded-r-lg border-l-2 border-cyan-400 bg-[#171717]/60 px-6 py-5 sm:px-8 sm:py-6"
          >
            <blockquote
              class="text-lg leading-relaxed text-white sm:text-xl md:text-2xl"
              style="font-family: 'Outfit', sans-serif"
            >
              &ldquo;cursor agent went off the hinges and started deleting my
              entire app. <span class="text-cyan-300"
                >90% of my app is gone</span
              > &hellip; I hadn't gotten a chance to push to github yet.&rdquo;
            </blockquote>
            <figcaption class="mt-4 text-xs text-[#737373]">
              &mdash; <span class="text-[#a3a3a3]">Jonneal3</span> &middot; May
              27, 2025 &middot;
              <a
                href="https://forum.cursor.com/t/help-needed-asap-cursor-deleted-my-whole-proejct/97589"
                target="_blank"
                rel="noopener"
                class="underline decoration-white/20 underline-offset-2 hover:text-white hover:decoration-white/50"
                >forum.cursor.com</a
              >
            </figcaption>
          </figure>
        </div>

        <p
          class="mx-auto mt-10 max-w-2xl text-center text-sm leading-relaxed text-[#a3a3a3]"
        >
          Cursor's official fix in 2026 is &ldquo;close the Agent Review
          Tab.&rdquo; Claude Code has no first-class undo. Cline's checkpoints
          are VSCode-bound. There is no editor-agnostic, dead-simple safety net
          for AI file edits. Until now.
        </p>
      </div>
    </section>

    <!-- ===================================================== HOW IT WORKS -->
    <section
      id="how"
      class="border-t border-white/5 py-16 sm:py-24 md:py-32"
    >
      <div class="mx-auto max-w-5xl px-6">
        <div class="mb-12 text-center">
