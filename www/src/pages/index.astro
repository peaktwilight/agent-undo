                code: "blake3 → CAS",
              },
              {
                n: "03",
                t: "Attribute",
                d: "The attribution layer tags the event with agent + session + prompt by sniffing the calling process.",
                code: "pid → agent",
              },
              {
                n: "04",
                t: "Recover",
                d: "Run au oops. The whole session reverts atomically. A new snapshot is made first — the undo is itself undoable.",
                code: "oops → atomic restore",
