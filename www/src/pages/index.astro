---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const installCmd = "curl -fsSL https://agent-undo.com/install.sh | sh";
const cargoCmd = "cargo install agent-undo";
const githubUrl = "https://github.com/peaktwilight/agent-undo";
---

<Layout>
  <Header />

  <main>
    <!-- ============================================================ HERO -->
    <section class="relative overflow-hidden border-b border-white/5">
      <div class="mx-auto max-w-7xl px-6 pt-20 pb-28 sm:pt-28 sm:pb-36 lg:pt-32 lg:pb-44">
        <div class="mb-10">
          <span class="text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            Source control for the code your agent wrote
          </span>
        </div>

        <h1
          class="max-w-5xl text-[clamp(2.6rem,7vw,6.5rem)] font-black leading-[0.98] tracking-[-0.015em] text-white"
          style="font-family: 'Outfit', 'Inter Variable', sans-serif; font-feature-settings: 'cv11', 'ss01';"
        >
          git for humans.<br />
          <code class="font-mono font-black text-cyan-400">au</code> for agents.
        </h1>

        <p class="mt-10 max-w-3xl text-lg leading-relaxed text-white/65 sm:text-xl">
          <span class="text-white">agent-undo</span> records every byte your AI coding agent writes,
          attributes it to the agent that made the change, and gives you one
          command to roll any session back. git versions your intent.
          <code class="font-mono text-white">au</code> records the agent's.
          <span class="text-white">They live alongside each other.</span>
        </p>

        <div class="mt-12 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <button
            type="button"
            class="copy-btn group inline-flex h-12 items-center gap-3 rounded-md border border-white/15 bg-white/[0.03] px-5 font-mono text-[14px] text-white transition-colors hover:border-white/35 hover:bg-white/[0.06]"
            data-copy={installCmd}
            aria-label="Copy install command"
          >
            <span class="text-white/40">$</span>
            <span>{installCmd}</span>
            <svg class="copy-icon h-4 w-4 text-white/40 transition-colors group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
              <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
            </svg>
            <svg class="check-icon hidden h-4 w-4 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </button>
          <a
            href={githubUrl}
            rel="noopener"
            class="inline-flex h-12 items-center gap-2 rounded-md border border-white/15 px-5 text-[14px] font-medium text-white transition-colors hover:border-white/35 hover:bg-white/5"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <p class="mt-10 max-w-2xl text-sm text-white/45">
          3.9 MB binary &middot; zero telemetry &middot; macOS + Linux &middot; MIT/Apache-2.0 &middot; <a href={`${githubUrl}/releases/latest`} rel="noopener" class="text-white/65 hover:text-white">latest release</a>
        </p>
      </div>
    </section>

    <!-- ===================================================== TERMINAL -->
    <section class="border-b border-white/5">
      <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
        <div class="overflow-hidden rounded-lg border border-white/10 bg-[#0f0f0f]">
          <div class="flex items-center gap-2 border-b border-white/10 bg-white/[0.02] px-4 py-2.5">
            <div class="flex gap-1.5">
              <div class="h-2.5 w-2.5 rounded-full bg-white/15"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-white/15"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-white/15"></div>
            </div>
            <span class="ml-2 font-mono text-[11px] text-white/45">~/my-project — au oops</span>
          </div>
          <div class="space-y-1 px-6 py-6 text-left font-mono text-[13px] leading-relaxed sm:text-[14px]">
            <div class="text-white/45">$ au oops</div>
            <div class="h-2"></div>
            <div class="text-white/85">
              ⚠  Last agent action: <span class="text-cyan-400">claude-code</span>, session 14:32–14:34, edited 5 files
            </div>
            <div class="pl-6 text-white/65">
              src/auth.rs <span class="text-white/35">(-87)</span> <span class="text-white/35">+12</span>
            </div>
            <div class="pl-6 text-white/65">
              src/middleware.rs <span class="text-white/35">(-23)</span> <span class="text-white/35">+5</span>
            </div>
            <div class="pl-6 text-white/65">
              src/lib.rs <span class="text-white/35">(-4)</span> <span class="text-white/35">+1</span>
            </div>
            <div class="pl-6 text-white/65">
              tests/auth.rs <span class="text-white/35">(deleted)</span>
            </div>
            <div class="pl-6 text-white/65">
              Cargo.toml <span class="text-white/35">(-2)</span> <span class="text-white/35">+0</span>
            </div>
            <div class="h-2"></div>
            <div class="text-white">
              Roll back this entire session? <span class="text-cyan-400">[Y/n]</span><span class="ml-0.5 inline-block h-3.5 w-1.5 align-middle bg-cyan-400"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ SHIFT -->
    <section id="category" class="border-b border-white/5">
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
        <div class="mb-16 max-w-3xl">
          <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            The shift
          </p>
          <h2
            class="text-4xl font-bold leading-[1.05] tracking-[-0.015em] text-white sm:text-5xl md:text-6xl"
            style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
          >
            Source control assumes a human writer.
            <span class="text-white/45">AI broke that assumption.</span>
          </h2>
        </div>

        <div class="grid gap-px overflow-hidden rounded-lg bg-white/10 md:grid-cols-2">
          <div class="bg-[#0a0a0a] p-8 sm:p-10">
            <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">git</p>
            <p class="mb-6 text-xl font-medium text-white">
              Versions human <span class="text-white/55">intent</span>.
            </p>
            <ul class="space-y-3 text-[15px] leading-relaxed text-white/65">
              <li>You commit when you mean to.</li>
              <li>Every change is a deliberate act.</li>
              <li>History reflects what you wanted to keep.</li>
              <li><code class="font-mono text-white/85">git blame</code> tells you which human wrote each line.</li>
            </ul>
          </div>

          <div class="bg-[#0a0a0a] p-8 sm:p-10">
            <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-400/80">
              au
            </p>
            <p class="mb-6 text-xl font-medium text-white">
              Records agent <span class="text-cyan-400">action</span>.
            </p>
            <ul class="space-y-3 text-[15px] leading-relaxed text-white/65">
              <li>Every byte is captured on write.</li>
              <li>No deliberate act required.</li>
              <li>History reflects what actually happened.</li>
              <li><code class="font-mono text-white/85">au blame</code> tells you which agent wrote each line.</li>
            </ul>
          </div>
        </div>

        <p class="mx-auto mt-12 max-w-3xl text-center text-[15px] leading-relaxed text-white/55">
          A 5-minute Claude session can produce 200 file writes. git sees zero of them
          until you type <code class="font-mono text-white/85">git add</code>.
          <code class="font-mono text-white/85">au</code> sees all of them, the moment
          they hit disk, tagged with the agent that made them.
          <span class="text-white">They're not competitors. They're complements.</span>
        </p>
      </div>
    </section>

    <!-- ============================================================ HOW -->
    <section id="how" class="border-b border-white/5">
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
        <div class="mb-16 max-w-3xl">
          <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            How it works
          </p>
          <h2
            class="text-4xl font-bold leading-[1.05] tracking-[-0.015em] text-white sm:text-5xl md:text-6xl"
            style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
          >
            A four-stage pipeline.
            <span class="text-white/45">Always on. Sub-1% CPU.</span>
          </h2>
        </div>

        <div class="grid gap-px overflow-hidden rounded-lg bg-white/10 md:grid-cols-4">
          {
            [
              { n: "01", t: "Watch", d: "notify-rs sees every write to your project tree. .gitignore is respected.", code: "fs.write → daemon" },
              { n: "02", t: "Snapshot", d: "BLAKE3 hash, content-addressable store. Identical content dedupes automatically.", code: "blake3 → CAS" },
              { n: "03", t: "Attribute", d: "A small JSON hook tags the event with the active agent, session, and tool.", code: "hook → session" },
              { n: "04", t: "Recover", d: "au oops rolls back the last agent burst, atomically. The undo is itself snapshotted.", code: "oops → restore" },
            ].map((step) => (
              <div class="bg-[#0a0a0a] p-8">
                <div class="mb-5 font-mono text-xs text-white/35">{step.n}</div>
                <h3 class="mb-3 text-base font-semibold text-white">{step.t}</h3>
                <p class="mb-6 text-sm leading-relaxed text-white/60">{step.d}</p>
                <div class="font-mono text-[11px] text-cyan-400/70">{step.code}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================================================ COMMANDS -->
    <section class="border-b border-white/5">
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
        <div class="mb-16 max-w-3xl">
          <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            What you type
          </p>
          <h2
            class="text-4xl font-bold leading-[1.05] tracking-[-0.015em] text-white sm:text-5xl md:text-6xl"
            style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
          >
            Two letters.
            <span class="text-white/45">Sixteen subcommands.</span>
          </h2>
        </div>

        <div class="grid gap-12 lg:grid-cols-2">
          <div>
            <h3 class="mb-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Setup</h3>
            <dl class="space-y-4 text-[14px]">
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au init</dt>
                <dd class="text-white/55">Scan project, set up <code class="font-mono">.agent-undo/</code></dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au init --install-hooks</dt>
                <dd class="text-white/55">Plus auto-install Claude Code hooks</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au serve --daemon</dt>
                <dd class="text-white/55">Background watcher</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au doctor</dt>
                <dd class="text-white/55">Diagnose project setup</dd>
              </div>
            </dl>

            <h3 class="mt-10 mb-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Read</h3>
            <dl class="space-y-4 text-[14px]">
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au log</dt>
                <dd class="text-white/55">Timeline of file events, attributed</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au sessions</dt>
                <dd class="text-white/55">List recent agent sessions</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au blame &lt;file&gt;</dt>
                <dd class="text-white/55">Per-line agent attribution</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au tui</dt>
                <dd class="text-white/55">Interactive timeline scrubber</dd>
              </div>
            </dl>
          </div>

          <div>
            <h3 class="mb-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Recover</h3>
            <dl class="space-y-4 text-[14px]">
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-cyan-400 shrink-0 sm:w-44">au oops</dt>
                <dd class="text-white/55">Undo the last burst of agent edits</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au restore --session &lt;id&gt;</dt>
                <dd class="text-white/55">Atomic multi-file rollback</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au pin &lt;label&gt;</dt>
                <dd class="text-white/55">Pin a known-good state</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au unpin &lt;label&gt;</dt>
                <dd class="text-white/55">Restore project to a pin</dd>
              </div>
            </dl>

            <h3 class="mt-10 mb-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Attribute</h3>
            <dl class="space-y-4 text-[14px]">
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au hook pre|post</dt>
                <dd class="text-white/55">Claude Code stdin-JSON protocol</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au exec --agent X</dt>
                <dd class="text-white/55">Wrap any CLI agent</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au diff --session &lt;id&gt;</dt>
                <dd class="text-white/55">Full session diff like a PR</dd>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <dt class="font-mono text-white shrink-0 sm:w-44">au gc</dt>
                <dd class="text-white/55">Garbage collect old events</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ VILLAIN -->
    <section class="border-b border-white/5">
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
        <div class="mb-16 max-w-3xl">
          <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            Why this exists
          </p>
          <h2
            class="text-4xl font-bold leading-[1.05] tracking-[-0.015em] text-white sm:text-5xl md:text-6xl"
            style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
          >
            Your editor's undo button
            <span class="text-white/45">is broken.</span>
          </h2>
          <p class="mt-6 max-w-2xl text-base text-white/60">
            Don't take our word for it. Take it from Cursor's own staff and users, on the record, on their own forum.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-2">
          <figure>
            <blockquote
              class="text-2xl leading-[1.3] font-medium text-white sm:text-3xl"
              style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
            >
              &ldquo;This is a known issue, a bug caused by a conflict between the Agent Review Tab and file editing. Close the Agent Review Tab before the agent makes edits.&rdquo;
            </blockquote>
            <figcaption class="mt-6 text-sm text-white/55">
              <span class="text-white">deanrie</span>, Cursor staff &middot; Jan 16, 2026 &middot;
              <a
                href="https://forum.cursor.com/t/agent-code-changes-are-automatically-deleted/149024"
                rel="noopener"
                class="underline decoration-white/20 underline-offset-4 hover:text-white hover:decoration-white/50"
              >forum.cursor.com</a>
            </figcaption>
          </figure>

          <figure>
            <blockquote
              class="text-2xl leading-[1.3] font-medium text-white sm:text-3xl"
              style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
            >
              &ldquo;cursor agent went off the hinges and started deleting my entire app. <span class="text-white/65">90% of my app is gone &hellip; I hadn't gotten a chance to push to github yet.</span>&rdquo;
            </blockquote>
            <figcaption class="mt-6 text-sm text-white/55">
              <span class="text-white">Jonneal3</span> &middot; May 27, 2025 &middot;
              <a
                href="https://forum.cursor.com/t/help-needed-asap-cursor-deleted-my-whole-proejct/97589"
                rel="noopener"
                class="underline decoration-white/20 underline-offset-4 hover:text-white hover:decoration-white/50"
              >forum.cursor.com</a>
            </figcaption>
          </figure>
        </div>

        <p class="mt-16 max-w-3xl text-base leading-relaxed text-white/55">
          Cursor's official fix in 2026 is &ldquo;close the Agent Review Tab.&rdquo;
          Claude Code has no first-class undo. Cline's checkpoints are VSCode-bound.
          There is no editor-agnostic, dead-simple safety net for AI file edits — until now.
        </p>
      </div>
    </section>

    <!-- ============================================================ INSTALL -->
    <section id="install" class="border-b border-white/5">
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
        <div class="mb-12 max-w-3xl">
          <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            Install
          </p>
          <h2
            class="text-4xl font-bold leading-[1.05] tracking-[-0.015em] text-white sm:text-5xl md:text-6xl"
            style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
          >
            One command.
            <span class="text-white/45">Three more, and you're protected.</span>
          </h2>
        </div>

        <div class="space-y-6">
          <button
            type="button"
            class="copy-btn group flex w-full items-center justify-between gap-4 rounded-md border border-white/15 bg-white/[0.03] px-6 py-5 text-left font-mono text-[14px] text-white transition-colors hover:border-white/35 hover:bg-white/[0.06] sm:text-[15px]"
            data-copy={installCmd}
            aria-label="Copy install command"
          >
            <span class="overflow-x-auto whitespace-nowrap">
              <span class="text-white/40">$</span> {installCmd}
            </span>
            <svg class="copy-icon h-4 w-4 shrink-0 text-white/40 transition-colors group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
              <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
            </svg>
            <svg class="check-icon hidden h-4 w-4 shrink-0 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </button>

          <div class="grid gap-3 sm:grid-cols-2">
            <button
              type="button"
              class="copy-btn group flex items-center justify-between gap-3 rounded-md border border-white/10 bg-white/[0.02] px-4 py-3 text-left font-mono text-[13px] text-white/80 transition-colors hover:border-white/25 hover:text-white"
              data-copy={cargoCmd}
              aria-label="Copy cargo install command"
            >
              <span><span class="text-white/40">$</span> {cargoCmd}</span>
              <svg class="copy-icon h-3.5 w-3.5 text-white/35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
              </svg>
              <svg class="check-icon hidden h-3.5 w-3.5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </button>
            <a
              href={`${githubUrl}/releases/latest`}
              rel="noopener"
              class="flex items-center justify-between gap-3 rounded-md border border-white/10 bg-white/[0.02] px-4 py-3 font-mono text-[13px] text-white/80 transition-colors hover:border-white/25 hover:text-white"
            >
              <span>download release binary</span>
              <svg class="h-3.5 w-3.5 text-white/35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
