---
/**
 * Landing page composition.
 *
 * Section list is intentionally tight (pwnkit-cloud OSS pattern):
 *
 *   Hero        — split-grid headline + terminal, single CTA
 *   Shift       — git/au two-card category claim
 *   Villain     — Cursor staff receipts (the proof)
 *   Install     — install command + 3-step guide
 *   Principle   — "the agent is an untrusted process" essay teaser
 *   FAQ         — 10 native <details> questions
 *   FinalCTA    — closing pill button
 *
 * Cut from earlier draft (kept in repo for /docs/* later, just not on the
 * landing): HeroTerminal (merged into Hero), HowItWorks, Commands.
 */
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/site/Hero.astro";
import Shift from "../components/site/Shift.astro";
import Villain from "../components/site/Villain.astro";
import Install from "../components/site/Install.astro";
import Principle from "../components/site/Principle.astro";
import FAQ from "../components/site/FAQ.astro";
import FinalCTA from "../components/site/FinalCTA.astro";

const installCmd = "curl -fsSL https://agent-undo.com/install.sh | sh";
const cargoCmd = "cargo install agent-undo";
const githubUrl = "https://github.com/peaktwilight/agent-undo";
---

<Layout>
  <Header />

  <main>
    <Hero installCmd={installCmd} githubUrl={githubUrl} />
    <Shift />
    <Villain />
    <Install installCmd={installCmd} cargoCmd={cargoCmd} githubUrl={githubUrl} />
    <Principle githubUrl={githubUrl} />
    <FAQ />
    <FinalCTA installCmd={installCmd} githubUrl={githubUrl} />
  </main>

  <Footer />
</Layout>

<script>
  // Vanilla copy-to-clipboard for [data-copy] elements.
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const trigger = target.closest("[data-copy]") as HTMLElement | null;
    if (!trigger) return;
    const text = trigger.getAttribute("data-copy");
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      const copy = trigger.querySelector(".copy-icon");
      const check = trigger.querySelector(".check-icon");
      copy?.classList.add("hidden");
      check?.classList.remove("hidden");
      setTimeout(() => {
        copy?.classList.remove("hidden");
        check?.classList.add("hidden");
      }, 1400);
    });
  });

  // Scroll-triggered fade-in for [data-reveal] elements.
  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -5% 0px", threshold: 0.08 },
    );
    document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => io.observe(el));
  } else {
    document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => el.classList.add("is-visible"));
  }
</script>
