---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageIntro from "../components/ui/PageIntro.astro";

const demos = [
  {
    title: "oops after a 5-file agent rampage",
    status: "Recording pending",
    blurb: "The hero clip: one session wrecks multiple files, `au oops` restores the rollback boundary, tests go green.",
    script: `cd demo-project
au init
au serve --daemon
# let an agent edit 5 files
au oops`,
  },
  {
    title: "oops apocalypse",
    status: "Recording pending",
    blurb: "Longer launch cut showing a real unattended run and a full rollback back to t=0.",
    script: `# real codebase, real session
au sessions
au diff --session <id>
au oops`,
  },
  {
    title: "au blame",
    status: "Screenshot pending",
    blurb: "The moat feature: one file, mixed human and agent edits, attribution line by line.",
    script: `au blame src/auth.rs`,
  },
  {
    title: "au tui",
    status: "Recording pending",
    blurb: "Interactive timeline scrubber for sessions, event diffs, and restore bookkeeping.",
    script: `au tui`,
  },
];
---

<Layout title="agent-undo demos" description="Planned launch demos and walkthroughs for agent-undo.">
  <Header />
  <main class="mx-auto min-h-[70vh] max-w-7xl px-6 py-20">
    <PageIntro
      eyebrow="Demos"
      title="Launch demo gallery"
      description="The route is live now; the final GIFs and screenshots drop in as they are recorded. The goal is one gallery page that can hold the hero clip, the attribution screenshot, and later community-contributed showcases across terminal agents and editors."
    />

    <div class="grid max-w-7xl gap-6 xl:grid-cols-2">
      {demos.map((demo) => (
        <section class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/[0.03] p-6">
          <div class="mb-5 flex items-center justify-between gap-4">
            <h2 class="text-2xl font-semibold tracking-tight text-white">{demo.title}</h2>
            <span class="rounded-full border border-amber-400/20 bg-amber-400/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-200">
              {demo.status}
            </span>
          </div>
          <p class="mb-5 text-sm leading-7 text-white/65">{demo.blurb}</p>
          <pre class="mt-auto overflow-x-auto rounded-2xl border border-white/10 bg-[#0a0a0a] px-5 py-4 text-sm text-white/85"><code>{demo.script}</code></pre>
        </section>
      ))}
    </div>

    <section class="mt-12 max-w-5xl rounded-3xl border border-white/10 bg-white/[0.03] p-6">
      <h2 class="text-2xl font-semibold tracking-tight text-white">Community slot</h2>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-white/65">
        Once the launch assets exist, this page can grow into a small showcase for pull requests
        that add new recovery scenarios, benchmark clips, or attribution walkthroughs from any
        agent workflow people are actually using.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
