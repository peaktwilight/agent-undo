---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageIntro from "../../components/ui/PageIntro.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="agent-undo blog" description="Essays and launch notes for agent-undo.">
  <Header />
  <main class="mx-auto min-h-[70vh] max-w-7xl px-6 py-20">
    <PageIntro
      eyebrow="Blog"
      title="Notes on rollback, attribution, and agent-written code"
      description="Essays, launch notes, and technical writeups about what changes when code is written by tools that move faster than commit cadence."
    />

    <div class="max-w-5xl space-y-6">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="block rounded-2xl border border-white/10 bg-white/[0.03] p-7 transition-colors hover:border-white/20 hover:bg-white/[0.05]"
        >
          <div class="mb-3 text-[12px] uppercase tracking-[0.18em] text-white/40">
            {post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">{post.data.title}</h2>
          <p class="mt-3 max-w-3xl text-sm leading-7 text-white/65">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>
