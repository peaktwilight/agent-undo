---
/**
 * pwnkit-cloud OSS-style footer. Hairline borders only.
 */
const year = new Date().getFullYear();
const githubUrl = "https://github.com/peaktwilight/agent-undo";
---
<footer class="relative mt-32 border-t border-white/5 bg-[#0a0a0a] text-white">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="mb-4 flex items-baseline gap-1.5">
          <span class="text-base font-semibold tracking-tight text-white">agent-undo</span>
          <span class="font-mono text-[12px] text-white/45">(au)</span>
        </div>
        <p class="max-w-sm text-sm leading-relaxed text-white/65">
          Local-first source control for the code your AI agent wrote.
          A single Rust binary, no telemetry, MIT/Apache-2.0.
        </p>
      </div>

      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Project</h4>
        <ul class="space-y-3 text-sm text-white/65">
          <li><a href="#category" class="hover:text-white">The shift</a></li>
          <li><a href="#how" class="hover:text-white">How it works</a></li>
          <li><a href="#install" class="hover:text-white">Install</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Reference</h4>
        <ul class="space-y-3 text-sm text-white/65">
          <li><a href={githubUrl} rel="noopener" class="hover:text-white">GitHub</a></li>
          <li><a href={`${githubUrl}/blob/main/PHILOSOPHY.md`} rel="noopener" class="hover:text-white">Philosophy</a></li>
          <li><a href={`${githubUrl}/blob/main/ARCHITECTURE.md`} rel="noopener" class="hover:text-white">Architecture</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/40">Install</h4>
        <ul class="space-y-3 text-sm text-white/65">
          <li><a href={`${githubUrl}/releases`} rel="noopener" class="hover:text-white">Releases</a></li>
          <li><a href="https://crates.io/crates/agent-undo" rel="noopener" class="hover:text-white">crates.io</a></li>
          <li><a href={`${githubUrl}/issues`} rel="noopener" class="hover:text-white">Issues</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 text-[11px] text-white/45 md:flex-row md:items-center">
      <span>© {year} agent-undo contributors. MIT &amp; Apache-2.0.</span>
      <span>git for humans. <code class="font-mono text-white/55">au</code> for agents.</span>
    </div>
  </div>
</footer>
