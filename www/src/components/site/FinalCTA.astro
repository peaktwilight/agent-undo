---
/**
 * FinalCTA — last section before the footer. White pill install button
 * for high contrast against the dark page, secondary "Read the source"
 * ghost button.
 */
import CopyButton from "../ui/CopyButton.astro";

interface Props {
  installCmd: string;
  githubUrl: string;
}
const { installCmd, githubUrl } = Astro.props;
---
<section>
  <div class="mx-auto max-w-7xl px-6 py-32 text-center">
    <h2
      data-reveal
      class="mx-auto max-w-3xl text-4xl font-bold leading-[1.05] tracking-[-0.02em] text-white sm:text-6xl"
      style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
    >
      Stop reconstructing<br />
      <span class="text-white/45">what your agent did after the fact.</span>
    </h2>
    <p data-reveal class="mx-auto mt-8 max-w-xl text-base leading-relaxed text-white/60">
      Install the binary. Start the watcher. Add hooks or wrap the CLI you use.
      Leave it alone until you need a rollback.
    </p>
    <div data-reveal class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <CopyButton
        command={installCmd}
        class="inline-flex h-12 items-center gap-3 rounded-md bg-white px-6 font-mono text-[14px] font-medium text-black transition-colors hover:bg-white/90"
        dollarClass="text-black/50"
        copyIconClass="text-black/50"
        checkIconClass="text-emerald-600"
      />
      <a
        href={githubUrl}
        rel="noopener"
        class="inline-flex h-12 items-center gap-2 rounded-md border border-white/15 px-6 text-[14px] font-medium text-white transition-colors hover:border-white/35 hover:bg-white/5"
      >
        Read the source
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
