---
/**
 * Hero — pwnkit-cloud split-grid pattern.
 * Headline column on the left (1.45fr) + terminal column (1fr) on lg+.
 * Single CTA: the cyan install command pill. Proof line below.
 */
import CopyButton from "../ui/CopyButton.astro";

interface Props {
  installCmd: string;
  githubUrl: string;
}
const { installCmd, githubUrl } = Astro.props;
---
<section class="relative isolate overflow-hidden border-b border-white/5">
  <div class="mx-auto max-w-7xl px-6 pt-20 pb-28 sm:pt-24 sm:pb-36 lg:pt-28 lg:pb-44">
    <div class="lg:grid lg:grid-cols-[1.45fr_1fr] lg:items-start lg:gap-12">
      <div>
        <div data-reveal class="mb-10">
          <span class="text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
            Source control for the code your agent wrote
          </span>
        </div>

        <h1
          data-reveal
          class="text-[clamp(2.4rem,5.4vw,5.25rem)] font-black leading-[0.98] tracking-[-0.018em] text-white"
          style="font-family: 'Outfit', 'Inter Variable', sans-serif; font-feature-settings: 'cv11', 'ss01';"
        >
          git for humans.<br />
          <span
            class="text-cyan-400"
            style="text-shadow: 0 0 48px rgba(6,182,212,0.55), 0 0 96px rgba(6,182,212,0.25);"
          >au</span>
          for agents.
        </h1>

        <div data-reveal class="mt-12 flex flex-wrap items-center gap-4">
          <CopyButton
            command={installCmd}
            class="inline-flex h-12 items-center gap-3 rounded-md bg-cyan-400 px-6 font-mono text-[14px] font-semibold text-black transition-colors hover:bg-cyan-300"
            dollarClass="text-black/55"
            copyIconClass="text-black/55"
            checkIconClass="text-emerald-700"
          />
        </div>

        <p data-reveal class="mt-10 max-w-2xl text-sm text-white/45">
          4&nbsp;MB Rust binary &middot;
          <a href="https://crates.io/crates/agent-undo" rel="noopener" class="text-white underline decoration-cyan-400/40 underline-offset-4 hover:decoration-cyan-400">agent-undo</a>
          on crates.io &middot; Apache-2.0
        </p>
      </div>

      {/* Terminal column — embedded in the hero on lg+, full-width below
          on smaller screens. No glow, hairline border, blinking cursor. */}
      <div data-reveal class="mt-14 lg:mt-0">
        <div class="overflow-hidden rounded-lg border border-white/10 bg-[#0f0f0f]">
          <div class="flex items-center gap-2 border-b border-white/10 bg-white/[0.02] px-4 py-2.5">
            <div class="flex gap-1.5">
              <div class="h-2.5 w-2.5 rounded-full bg-white/15"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-white/15"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-white/15"></div>
            </div>
            <span class="ml-2 font-mono text-[11px] text-white/45">~/my-project</span>
          </div>
          <div class="space-y-1 px-5 py-5 text-left font-mono text-[12px] leading-relaxed sm:text-[13px]">
            <div class="text-white/45">$ au oops</div>
            <div class="h-1.5"></div>
            <div class="text-white/85">
              ⚠  <span class="text-cyan-400">claude-code</span> · 14:32 · 5 files
            </div>
            <div class="pl-5 text-white/60">src/auth.rs <span class="text-white/30">(-87)</span></div>
            <div class="pl-5 text-white/60">src/middleware.rs <span class="text-white/30">(-23)</span></div>
            <div class="pl-5 text-white/60">src/lib.rs <span class="text-white/30">(-4)</span></div>
            <div class="pl-5 text-white/60">tests/auth.rs <span class="text-white/30">(deleted)</span></div>
            <div class="pl-5 text-white/60">Cargo.toml <span class="text-white/30">(-2)</span></div>
            <div class="h-1.5"></div>
            <div class="text-white">
              Roll back? <span class="text-cyan-400">[Y/n]</span><span class="blink ml-0.5 inline-block h-3 w-1.5 align-middle bg-cyan-400"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
