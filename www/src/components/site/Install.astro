---
/**
 * Install — centered header, install pill, cargo + release alternates.
 * The three-step grid is gone: if you can read the install command,
 * you know what to do next.
 */
interface Props {
  installCmd: string;
  cargoCmd: string;
  githubUrl: string;
}
const { installCmd, cargoCmd, githubUrl } = Astro.props;
---
<section id="install" class="border-b border-white/5">
  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
    <div data-reveal class="mx-auto mb-12 max-w-3xl text-center">
      <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
        Install
      </p>
      <h2
        class="text-4xl font-bold leading-[1.05] tracking-[-0.02em] text-white sm:text-5xl md:text-6xl"
        style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
      >
        One command.
        <span class="text-white/45">No account. No telemetry.</span>
      </h2>
    </div>

    <div data-reveal class="mx-auto max-w-3xl space-y-4">
      <button
        type="button"
        class="copy-btn group flex w-full items-center justify-between gap-4 rounded-md border border-white/15 bg-white/[0.03] px-6 py-5 text-left font-mono text-[14px] text-white transition-colors hover:border-white/35 hover:bg-white/[0.06] sm:text-[15px]"
        data-copy={installCmd}
        aria-label="Copy install command"
      >
        <span class="overflow-x-auto whitespace-nowrap">
          <span class="text-white/40">$</span> {installCmd}
        </span>
        <svg class="copy-icon h-4 w-4 shrink-0 text-white/40 transition-colors group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
        </svg>
        <svg class="check-icon hidden h-4 w-4 shrink-0 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>

      <div class="grid gap-3 sm:grid-cols-2">
        <button
          type="button"
          class="copy-btn group flex items-center justify-between gap-3 rounded-md border border-white/10 bg-white/[0.02] px-4 py-3 text-left font-mono text-[13px] text-white/80 transition-colors hover:border-white/25 hover:text-white"
          data-copy={cargoCmd}
          aria-label="Copy cargo install command"
        >
          <span><span class="text-white/40">$</span> {cargoCmd}</span>
          <svg class="copy-icon h-3.5 w-3.5 text-white/35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
          </svg>
          <svg class="check-icon hidden h-3.5 w-3.5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
        <a
          href={`${githubUrl}/releases/latest`}
          rel="noopener"
          class="flex items-center justify-between gap-3 rounded-md border border-white/10 bg-white/[0.02] px-4 py-3 font-mono text-[13px] text-white/80 transition-colors hover:border-white/25 hover:text-white"
        >
          <span>download release binary</span>
          <svg class="h-3.5 w-3.5 text-white/35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
