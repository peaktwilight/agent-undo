---
/**
 * FAQ — native <details> accordion. Zero JS. Centered header, left-aligned
 * question list inside a centered max-w-4xl container.
 *
 * Trimmed from 10 → 7: cut 'stability', 'performance cost', and 'does my
 * code leave my machine' — those are already answered by the crates.io
 * link, the 'local-first' eyebrow, and the fact that the page exists.
 *
 * Typography: standalone 'au'/'git' as project names use <span> with a
 * color only. Real commands, file paths, and literal values use <code>.
 */
const faqs: { q: string; a: string }[] = [
  {
    q: "How is this different from git?",
    a: "<span class=\"text-white/85\">git</span> versions intent — commits are deliberate acts. <span class=\"text-cyan-400\">au</span> records action — every byte, the moment it hits disk. You run both.",
  },
  {
    q: "Does it replace my editor's undo?",
    a: "No. Editor undo is in-memory and editor-bound. <span class=\"text-cyan-400\">au</span> is on-disk, editor-agnostic, and survives crashes, restarts, and agent rampages.",
  },
  {
    q: "Does it work with Cursor, Cline, Aider, Codex?",
    a: "Yes. A zero-config heuristic watches every filesystem write regardless of source. Hooks add perfect attribution when the agent exposes one — Claude Code today, Cursor/Cline/Aider via adapters shipping in v0.1.",
  },
  {
    q: "Does it touch my .git directory?",
    a: "Never. <span class=\"text-cyan-400\">au</span> maintains its own store under <code class=\"font-mono text-white/85\">.agent-undo/</code>. If your agent nukes <code class=\"font-mono text-white/85\">.git</code> itself, <span class=\"text-cyan-400\">au</span> is unaffected and can still roll everything back.",
  },
  {
    q: "What if the daemon isn't running when my agent writes?",
    a: "You miss those events. No daemon, no capture. <code class=\"font-mono text-white/85\">au init --install-hooks</code> sets up a per-project daemon that starts automatically. <code class=\"font-mono text-white/85\">au doctor</code> tells you at a glance whether it's alive.",
  },
  {
    q: "How much disk does it use?",
    a: "Content-addressable and deduped — usually under 100 MB on an active project. <code class=\"font-mono text-white/85\">au gc</code> runs a 7-day cutoff by default and sweeps orphaned blobs.",
  },
  {
    q: "Can I run it on CI?",
    a: "You can, but it's built for local use. CI is already good at capturing state via commits and artifacts. <span class=\"text-cyan-400\">au</span> fills the gap in the inner-loop dev environment, where agents move faster than your commit cadence.",
  },
];
---
<section class="border-b border-white/5">
  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
    <div data-reveal class="mx-auto mb-16 max-w-3xl text-center">
      <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-white/55">
        Questions
      </p>
      <h2
        class="text-4xl font-bold leading-[1.05] tracking-[-0.02em] text-white sm:text-5xl md:text-6xl"
        style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
      >
        Seven things developers ask
        <span class="text-white/45">before they install.</span>
      </h2>
    </div>

    <div data-reveal class="mx-auto max-w-3xl">
      {faqs.map((faq) => (
        <details class="group border-b border-white/5 py-6 last:border-b-0">
          <summary class="flex cursor-pointer items-start justify-between gap-4 text-left">
            <span class="text-[17px] font-medium text-white group-hover:text-white">
              {faq.q}
            </span>
            <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center text-white/45 transition-transform duration-200 group-open:rotate-45">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <div
            class="mt-4 pr-8 text-[15px] leading-relaxed text-white/65"
            set:html={faq.a}
          />
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
  details > summary {
    list-style: none;
  }
</style>
