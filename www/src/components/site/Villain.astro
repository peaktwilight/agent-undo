---
/**
 * Villain — the receipts. Centered header, two full pull quotes.
 * The longer quote bodies stay because the voice matters — punchlines
 * were too clean; the original language is the proof.
 */
import SectionHeader from "../ui/SectionHeader.astro";
import PullQuote from "../ui/PullQuote.astro";
---
<section class="border-b border-white/5">
  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
    <SectionHeader eyebrow="Why this exists">
      Your editor's undo
      <span class="text-white/45">is broken.</span>
    </SectionHeader>

    <div data-reveal class="mx-auto grid max-w-6xl gap-16 lg:grid-cols-2">
      <PullQuote
        quote="This is a known issue, a bug caused by a conflict between the Agent Review Tab and file editing. Close the Agent Review Tab before the agent makes edits."
        author="deanrie"
        role="Cursor staff"
        date="Jan 16, 2026"
        href="https://forum.cursor.com/t/agent-code-changes-are-automatically-deleted/149024"
      />

      <PullQuote
        quote={`cursor agent went off the hinges and started deleting my entire app. <span class="text-white/65">90% of my app is gone &hellip; I hadn't gotten a chance to push to github yet.</span>`}
        author="Jonneal3"
        date="May 27, 2025"
        href="https://forum.cursor.com/t/help-needed-asap-cursor-deleted-my-whole-proejct/97589"
      />
    </div>
  </div>
</section>
