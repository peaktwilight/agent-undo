---
/**
 * Principle — manifesto section. Centered header + centered prose column.
 */
import SectionHeader from "../ui/SectionHeader.astro";

interface Props {
  githubUrl: string;
}
const { githubUrl } = Astro.props;
---
<section class="border-b border-white/5">
  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32">
    <SectionHeader eyebrow="The principle" mb="mb-12">
      The agent is<br />
      <span class="text-amber-300">an untrusted process.</span>
    </SectionHeader>

    <div class="mx-auto max-w-2xl">
      <div data-reveal class="space-y-6 text-[17px] leading-[1.65] text-white/65">
        <p>
          Every piece of engineering ceremony &mdash; commits, review, blame, audit &mdash;
          assumed one thing: the writer of the code is a human you can hold accountable.
        </p>
        <p>
          That assumption broke. Agents silently delete tests, rewrite mocks to pass,
          refactor across boundaries without understanding intent. A bad decision at
          14:32:07 is 200 files deep by 14:32:42.
        </p>
        <p class="text-white">
          Treat AI coding agents the way a security engineer treats any process with
          write access: assume it will eventually do something wrong, and build the
          controls that let you recover.
        </p>
        <p>
          <span class="text-amber-300">au</span> is the substrate.
          Observability, attribution, reversibility &mdash; the three primitives the next
          decade of agent-aware tooling will be built on.
        </p>
      </div>
      <div data-reveal class="mt-10 text-center">
        <a
          href={`${githubUrl}/blob/main/PHILOSOPHY.md`}
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm text-white/65 underline decoration-white/20 underline-offset-4 hover:text-white hover:decoration-white/50"
        >
          Read the full essay
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
