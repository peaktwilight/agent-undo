---
/**
 * PullQuote — a large blockquote with attribution.
 * Used in Villain section for the Cursor forum receipts.
 *
 * `quote` is HTML-allowed (so you can wrap parts in `<span class="text-white/65">`
 * for an emphasis-within-a-quote effect).
 */
interface Props {
  quote: string;
  author: string;
  role?: string;
  date: string;
  href: string;
  linkText?: string;
}

const {
  quote,
  author,
  role,
  date,
  href,
  linkText = "forum.cursor.com",
} = Astro.props;
---
<figure>
  <blockquote
    class="text-2xl leading-[1.3] font-medium text-white sm:text-3xl"
    style="font-family: 'Outfit', 'Inter Variable', sans-serif;"
    set:html={`&ldquo;${quote}&rdquo;`}
  />
  <figcaption class="mt-6 text-sm text-white/55">
    <span class="text-white">{author}</span>{role && `, ${role}`} &middot; {date} &middot;
    <a
      href={href}
      rel="noopener"
      class="underline decoration-white/20 underline-offset-4 hover:text-white hover:decoration-white/50"
    >
      {linkText}
    </a>
  </figcaption>
</figure>
