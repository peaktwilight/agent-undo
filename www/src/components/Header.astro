---
/**
 * Sticky top header — pwnkit-cloud OSS pattern.
 *
 * 64px bar with the wordmark left, nav center, GitHub button right.
 * No floating dock pill. No pulsing indicators. The "glass" feel comes
 * from the ProgressiveBlur stack underneath the bar — 8 backdrop-filter
 * layers with exponentially increasing blur amounts, so content
 * dissolves smoothly into the header instead of hitting a hard cutoff.
 */
import ProgressiveBlur from "./ProgressiveBlur.astro";

const githubUrl = "https://github.com/peaktwilight/agent-undo";
---
<header class="sticky top-0 z-40 h-16">
  {/* Progressive blur stack — pure CSS, zero JS, the iOS liquid glass effect.
      tint=transparent means the blur layers don't add any color overlay,
      so the bar reads on top of any background. */}
  <ProgressiveBlur
    direction="top"
    height="h-28"
    tint="bg-transparent"
    class="absolute inset-x-0 top-0"
  />

  <div class="relative mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a href="/" class="flex items-baseline gap-1.5 text-[15px] font-semibold tracking-tight text-white">
      <span>agent-undo</span>
      <span class="font-mono text-[12px] font-normal text-white/40">(au)</span>
    </a>

    <nav aria-label="primary" class="hidden items-center gap-7 md:flex">
      <a href="#category" class="text-[13px] font-medium text-white/60 transition-colors hover:text-white">
        The shift
      </a>
      <a href="#install" class="text-[13px] font-medium text-white/60 transition-colors hover:text-white">
        Install
      </a>
      <a href={githubUrl} rel="noopener" class="text-[13px] font-medium text-white/60 transition-colors hover:text-white">
        Source
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={githubUrl}
        rel="noopener"
        aria-label="agent-undo on GitHub"
        class="inline-flex h-9 items-center gap-2 rounded-md border border-white/15 px-4 text-[13px] font-medium text-white transition-colors hover:border-white/35 hover:bg-white/5"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
    </div>
  </div>
</header>
